<?xml version="1.0" encoding="utf-8"?>
<!--
  CI smoke tests only (see build.yml). Pins LanceDB to the locally packed nupkg
  (LANCEDB_LOCAL_FEED) so the published package on nuget.org can't shadow the build
  under test. Copied next to the smoke consumer; not auto-applied to normal builds
  since it lives under .github/workflows/, never an ancestor of the real projects.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="local" value="%LANCEDB_LOCAL_FEED%" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="local">
      <package pattern="LanceDB" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
